CHECKED="false" # After reviewing change to true

# Disk
DRIVE="/dev/<fillin>" # Drive on which the system will be installed

# NVMe/eMMC devices need a 'p' before the partition number (e.g. nvme0n1p1),
# plain SATA/virtio devices don't (e.g. sda1). Detect automatically.
case "$DRIVE" in
  *nvme*|*mmcblk*) PART_SUFFIX="p" ;;
  *)               PART_SUFFIX="" ;;
esac
EFI_PART="${DRIVE}${PART_SUFFIX}1"
LUKS_PART="${DRIVE}${PART_SUFFIX}2"

# Installation tuning
EFI_SIZE="1G"                    # EFI system partition size
BTRFS_COMPRESSION="zstd:3"       # Btrfs compression (algorithm:level)
NETWORK_CHECK_HOST="1.1.1.1"     # Host to ping for connectivity check
NVIDIA_DRIVER="nvidia"           # nvidia (proprietary) or nvidia-open

# System
SWAP_SIZE="8g"
TIMEZONE="Europe/Warsaw"
HOSTNAME="arch"
ADMIN_USER="admin"

DESKTOP_USERS=(
  "${ADMIN_USER}:wheel"
  "code:video,render"
  "gaming:video,render"
)

# Locales (space-separated; LANG is set separately below)
LOCALES="en_US.UTF-8 pl_PL.UTF-8"
LANG="en_US.UTF-8"

# Kernels to build UKI, each entry creates a matching /etc/mkinitcpio.d/<name>.preset
KERNELS="linux linux-lts"

# EFI boot entry labels (must match order of KERNELS)
EFI_LABELS="Arch Linux|Arch Linux LTS"
SYSTEM_WIDE_DEST="/mnt/opt/simple-linux"

# Packages (space-separated, add/remove as needed) CPU microcode package is auto-detected (intel-ucode/amd-ucode)
PACKAGES="base base-devel ${KERNELS} linux-firmware fwupd btrfs-progs snapper efibootmgr networkmanager nftables openssh sudo vim git rsync wget unzip sbctl cmake"

HYPRLAND_PACKAGES="hyprland hyprpaper hyprshutdown hyprpolkitagent hyprlock hyprland-qt-support hyprsunset pipewire pipewire-pulse wireplumber xdg-desktop-portal-hyprland xdg-desktop-portal-gtk noto-fonts ttf-dejavu"
THEME_PACKAGES="qt5-wayland qt6-wayland qt6-5compat qt5ct qt6ct adw-gtk-theme"
YAZI_PACKAGES="nerd-fonts yazi ffmpeg 7zip jq poppler fd ripgrep fzf zoxide resvg imagemagick wl-clipboard"
QUICKSHELL_PACKAGES="quickshell qt5-svg qt6-svg qt5-imageformats qt6-imageformats qt5-multimedia qt6-multimedia socat"
BLUETOOTH_PACKAGES="bluez bluez-utils bluetui"
MISC_PACKAGES="nm-connection-editor swappy kitty mpv fastfetch pavucontrol feh bc matugen ddcutil man zenity flatpak flatseal nerdctl"

OTHER_PACKAGES="${THEME_PACKAGES} ${YAZI_PACKAGES} ${QUICKSHELL_PACKAGES} ${BLUETOOTH_PACKAGES} ${MISC_PACKAGES}"

# Services
SYSTEMD_SYSTEM_SERVICES="NetworkManager nftables fstrim.timer bluetooth snapper-timeline.timer snapper-cleanup.timer"
