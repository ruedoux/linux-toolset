CHECKED="true" # After reviewing change to true

# Disk
DRIVE="/dev/nvme0n1" # Drive on which the system will be installed

# NVMe/eMMC devices need a 'p' before the partition number (e.g. nvme0n1p1),
# plain SATA/virtio devices don't (e.g. sda1). Detect automatically.
case "$DRIVE" in
  *nvme*|*mmcblk*) PART_SUFFIX="p" ;;
  *)               PART_SUFFIX="" ;;
esac
EFI_PART="${DRIVE}${PART_SUFFIX}1"
LUKS_PART="${DRIVE}${PART_SUFFIX}2"

# Installation tuning
EFI_SIZE="2G"
BTRFS_COMPRESSION="zstd:3"
NETWORK_CHECK_HOST="1.1.1.1"

# GPU drivers, autodetected
GPU_NVIDIA_DRIVERS="nvidia nvidia-utils"
GPU_AMD_DRIVERS="mesa vulkan-radeon libva-mesa-driver"
GPU_INTEL_DRIVERS="mesa vulkan-intel intel-media-driver"

# System
SWAP_SIZE="8g"
TIMEZONE="Europe/Warsaw"
HOSTNAME="arch"
ADMIN_USER="admin"

DESKTOP_USERS=(
  "${ADMIN_USER}:wheel"
  "code:video,render"
  "gaming:video,render"
)

# Locales (space-separated; LANG is set separately below)
LOCALES="en_US.UTF-8 pl_PL.UTF-8"
LANG="en_US.UTF-8"

# Kernels to build UKI, each entry creates a matching /etc/mkinitcpio.d/<name>.preset
KERNELS="linux linux-lts"
EFI_LABELS="Arch Linux|Arch Linux LTS" # EFI boot entry labels (must match order of KERNELS)
SYSTEM_WIDE_DEST="/opt/simple-linux"

# Packages (space-separated, add/remove as needed) CPU microcode package is auto-detected (intel-ucode/amd-ucode)
PACKAGES="base base-devel ${KERNELS} linux-firmware fwupd btrfs-progs timeshift efibootmgr networkmanager nftables openssh sudo vim git rsync wget unzip sbctl cmake usbutils strace"

HYPRLAND_PACKAGES="hyprland hyprpaper hypridle hyprshutdown hyprpolkitagent hyprlock hyprland-qt-support hyprsunset pipewire wireless-regdb pipewire-pulse wireplumber pipewire-libcamera xdg-desktop-portal-hyprland xdg-desktop-portal-gtk noto-fonts ttf-dejavu brightnessctl"
THEME_PACKAGES="qt5-wayland qt6-wayland qt6-5compat qt5ct qt6ct adw-gtk-theme"
YAZI_PACKAGES="nerd-fonts yazi ffmpeg 7zip jq poppler fd ripgrep fzf zoxide resvg imagemagick wl-clipboard"
QUICKSHELL_PACKAGES="quickshell qt5-svg qt6-svg qt5-imageformats qt6-imageformats qt5-multimedia qt6-multimedia socat"
BLUETOOTH_PACKAGES="bluez bluez-utils bluetui"
NVIM_PACKAGES="neovim tree-sitter-cli lua-jsregexp"
MISC_PACKAGES="nm-connection-editor grim slurp kitty mpv fastfetch pavucontrol feh bc matugen ddcutil man zenity flatpak flatseal nerdctl htop rtkit upower"

OTHER_PACKAGES="${THEME_PACKAGES} ${YAZI_PACKAGES} ${QUICKSHELL_PACKAGES} ${BLUETOOTH_PACKAGES} ${NVIM_PACKAGES} ${MISC_PACKAGES}"

# Services
SYSTEMD_SYSTEM_SERVICES="fstrim.timer bluetooth upower"
SYSTEMD_CHROOT_SERVICES="NetworkManager nftables systemd-resolved"
